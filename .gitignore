# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
env/
venv/
.venv/
venv.bak/
instance/
pip-wheel-metadata/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
pip-log.txt
pip-delete-this-directory.txt

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
pytest_cache/
.pytest_cache/
nosetests.xml
coverage.xml
*.cover
.hypothesis/

# Translations
*.mo
*.pot

# Django stuff:
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal
/instance/
/media/
/staticfiles/
# If you collect static files into a folder for deployment, ignore that built folder.
# If you commit static/* (source) keep that; but collected files (e.g. staticfiles/) typically ignored.

# Django migrations caches and compiled python files
# (keep actual migration .py files — do NOT ignore migrations/ in general)
__pycache__/
*.pyc
*.pyo

# Environment variables
.env
.env.*.local
.env.local
.env.production
.env.development

# Secrets, keys
secret_key.txt
*.pem
*.key

# IDEs and editors
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# macOS
.DS_Store

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# JetBrains
/.idea
*.iml

# Editor swap files
*~
*.swp
.*.swp

# node / frontend (if you have frontend tooling)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
dist/
build/

# Python language server caches
.mypy_cache/
.pyre/
.pytype/

# celery
celerybeat-schedule
celerybeat.pid

# coverage reports
coverage/
coverage.*
